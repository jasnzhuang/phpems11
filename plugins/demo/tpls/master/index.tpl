{x2;include:header}<body><div class="container-fluid">	<div class="row-fluid">		<div class="box itembox" style="margin-bottom:0px;border-bottom:1px solid #CCCCCC;">			<div class="col-xs-12">				<ol class="breadcrumb">					<li class="active">插件演示</li>				</ol>			</div>		</div>		<div class="box itembox" style="padding-top:10px;margin-bottom:0px;">			<h4 class="title" style="padding:10px;">				插件设置				<a class="btn btn-primary pull-right" href="javascript:;" onclick="window.parent.location.reload()">返回</a>			</h4>			<form action="index.php?plugin-master-demo" method="post" class="form-horizontal" style="padding-top:10px;margin-bottom:0px;">				<div class="form-group">					<label class="col-sm-2 control-label">注册增加积分：</label>					<div class="col-sm-10">						<label class="radio-inline">							<input name="args[coinnumber]" class="form-control" type="text" value="{x2;$setting['coinnumber']}"/>						</label>						<span class="help-block">填写赠送积分的数量。</span>					</div>				</div>				<div class="form-group">					<label class="col-sm-2 control-label">阅读计数增加：</label>					<div class="col-sm-10">						<label class="radio-inline">							<input name="args[viewnumber]" class="form-control" type="text" value="{x2;$setting['viewnumber']}"/>						</label>						<span class="help-block">填写增加的数量。</span>					</div>				</div>				<div class="form-group">					<label for="seo_description" class="col-sm-2 control-label"></label>					<div class="col-sm-9">						<button class="btn btn-primary" type="submit">提交</button>						<input type="hidden" name="pluginconfig" value="1"/>					</div>				</div>			</form>		</div>	</div></div></body></html>