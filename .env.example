# ============================================
# PHPEMS 敏感配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# 数据库配置
DB_NAME=your_database_name
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASS=your_db_password

# Session / 加密密钥（请使用随机生成的 32 位字符串）
CSKEY=your_random_32_char_key_here____
CSIV=1234567812345678

# 微信开放平台
OPENAPPID=your_open_appid
OPENAPPSECRET=your_open_appsecret
MPAPPID=your_mp_appid
MPAPPSECRET=your_mp_appsecret
WXAPPID=your_wx_appid
WXAPPSECRET=your_wx_appsecret
WXMCHID=your_mch_id
WXKEY=your_wx_key

# 支付宝
ALIAPPID=your_ali_appid
ALIPRIKEY=your_ali_private_key
ALIPUBKEY=your_ali_public_key

# APP 配置（请使用随机生成的 32 位字符串）
APPKEY=your_random_32_char_key_here____
APPIV=1234567812345678

# 百度 AI
BAIDU_CLIENT_ID=your_baidu_client_id
BAIDU_CLIENT_SECRET=your_baidu_client_secret
