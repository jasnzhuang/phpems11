{x2;include:header}<body>{x2;include:nav}<div class="container-fluid">	<div class="row-fluid">		<div class="main">			<div class="col-xs-2 leftmenu">                {x2;include:menu}			</div>			<div id="datacontent">				<div class="box itembox" style="margin-bottom:0px;border-bottom:1px solid #CCCCCC;">					<div class="col-xs-12">						<ol class="breadcrumb">							<li><a href="index.php?{x2;$_app}-master">{x2;$apps[$_app]['appname']}</a></li>							<li class="active">插件管理</li>						</ol>					</div>				</div>				<div class="box itembox" style="padding-top:20px;margin-bottom:0px;">					<h4 class="title">						插件管理					</h4>					<table class="table table-bordered table-hover">						<thead>							<tr class="info">								<th width="100">									插件标识								</th>								<th width="160">									插件名称								</th>								<th>									简介								</th>								<th width="100">									状态								</th>								<th width="120">									操作								</th>							</tr>						</thead>						<tbody>							{x2;tree:$plugins,plugin,pid}							<tr>								<td>{x2;v:plugin['name']}</td>								<td>									{x2;v:plugin['title']}								</td>								<td>									{x2;v:plugin['describe']}								</td>								<td>									{x2;if:v:plugin['actived']}									<a class="confirm" msg="确定要禁用吗？" href="index.php?plugin-master-plugins-off&plugin={x2;v:plugin['name']}">启用</a>									{x2;elseif:v:plugin['installed']}									<a class="confirm" msg="确定要启用吗？" href="index.php?plugin-master-plugins-on&plugin={x2;v:plugin['name']}">禁用</a>									{x2;else}									<a class="confirm" msg="确定要按安装吗？" href="index.php?plugin-master-plugins-on&plugin={x2;v:plugin['name']}">未安装</a>									{x2;endif}								</td>								<td class="text-center">									{x2;if:v:plugin['manageUrl'] && v:plugin['actived']}									<a class="pluginmanager" href="{x2;v:plugin['manageUrl']}">管理</a>									{x2;endif}									{x2;if:v:plugin['installed'] && !v:plugin['actived']}									<a class="confirm" msg="卸载会删除数据，确定要卸载吗？" href="index.php?plugin-master-plugins-uninstall&plugin={x2;v:plugin['name']}">卸载</a>									{x2;endif}								</td>							</tr>							{x2;endtree}						</tbody>					</table>				</div>			</div>		</div>	</div></div>{x2;include:footer}</body></html>